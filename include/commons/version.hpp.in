#pragma once

/// @file
/// @brief Numeric and string version of the Commons headers. Generated by the
///        build system from `version.hpp.in` (the single source is the
///        `project()` / `project` version in CMake / Meson).

#include <string_view>

// NOLINTBEGIN(cppcoreguidelines-macro-to-enum,modernize-macro-to-enum)
#define COMMONS_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define COMMONS_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define COMMONS_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define COMMONS_VERSION_STRING "@PROJECT_VERSION@"
// NOLINTEND(cppcoreguidelines-macro-to-enum,modernize-macro-to-enum)

namespace comms {

/// Library version as a string, e.g. "0.1.0".
inline constexpr std::string_view version = COMMONS_VERSION_STRING;

inline constexpr int version_major = COMMONS_VERSION_MAJOR;
inline constexpr int version_minor = COMMONS_VERSION_MINOR;
inline constexpr int version_patch = COMMONS_VERSION_PATCH;

}  // namespace comms
